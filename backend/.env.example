# TrustCircle Backend Environment Variables
# Copy this file to .env and fill in your values

# Creditcoin Testnet RPC URL
CREDITCOIN_RPC_URL=https://rpc.testnet.creditcoin.org

# Your 4x contract addresses - comma-separated
CONTRACT_ADDRESSES=0x0000000000000000000000000000000000000001,0x0000000000000000000000000000000000000002,0x0000000000000000000000000000000000000003,0x0000000000000000000000000000000000000004
TRUSTCIRCLE_CONTRACTS=0x0000000000000000000000000000000000000001,0x0000000000000000000000000000000000000002,0x0000000000000000000000000000000000000003,0x0000000000000000000000000000000000000004

# Redis connection (optional - app works without Redis)
REDIS_URL=redis://localhost:6379

# Server port
PORT=3001

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173
