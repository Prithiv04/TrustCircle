# TrustCircle Frontend Environment Variables
# Copy this file to .env and fill in your values

# Your 4x TrustCircle contract addresses on Creditcoin Testnet
# Comma-separated list
VITE_CONTRACT_ADDRESSES=0x0000000000000000000000000000000000000001,0x0000000000000000000000000000000000000002,0x0000000000000000000000000000000000000003,0x0000000000000000000000000000000000000004

# Creditcoin Testnet RPC URL
VITE_CREDITCOIN_RPC=https://rpc.testnet.creditcoin.org

# WalletConnect Project ID (get from cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your-project-id-here

# Backend API URL
VITE_API_URL=http://localhost:3001
VITE_BACKEND_URL=http://localhost:3001
